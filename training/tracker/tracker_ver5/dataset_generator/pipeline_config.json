{
    "carla": {
        "host": "127.0.0.1",
        "port": 2000,
        "timeout": 30.0,
        "maps": ["Town10HD_Opt", "Town04_Opt", "Town05_Opt", "Town01_Opt", "Town02_Opt", "Town03_Opt", "Town06_Opt", "Town07_Opt", "Town08_Opt", "Town09_Opt", "Town11_Opt", "Town12_Opt"],
        "weather_presets": ["Sunset"]
    },
    "sensor": {
        "width": 800,
        "height": 600,
        "fov": 90.0,
        "fov_range": [45.0, 145.0],
        "fps": 30
    },
    "generation": {
        "output_dir": "outputs",
        "cache_dir": "cache",
        "debug_dir": "debug",
        "num_flights_to_cache": 6000,
        "frames_per_flight": 8,
        "num_false_negatives": 4,
        "debug_interval": 50,
        "min_texture_std": 2.0,
        "noise_params": {
            "pos_xy_amp": 0.3,
            "pos_z_amp": 0.1,
            "rot_pitch_amp": 0.5,
            "rot_yaw_amp": 0.5,
            "rot_roll_amp": 2.5
        },
        "target_distance": {
            "use_altitude_scaled_defaults": true,
            "allowed_range_m": [30, 250],
            "exclude_ranges_m": []
        },
        "flight_motion": {
            "longitudinal_mode": "random_signed",
            "longitudinal_delta_range_m": [-30.0, 30.0],
            "allow_approach": true,
            "allow_recede": true,
            "stop_distance_range_m": [20.0, 30.0]
        },
        "lateral_motion": {
