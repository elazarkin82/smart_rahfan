        },
        "secondary_capture_delay_sec": 2.0,
        "altitude_range": [2.0, 60.0]
    },
    "compiler": {
        "dataset_dir": "compiled",
        "stack_layers": 2,
        "stack_target_size": 64,
        "crop_max_size": [256, 512],
        "crop_min_size": 64,
        "heatmap_sigma": 10.0,
        "heatmap_relative_sigma": 0.125,
        "synthetic_negative_ratio": 0.00
