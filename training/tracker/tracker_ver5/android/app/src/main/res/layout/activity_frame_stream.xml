<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fitsSystemWindows="false"
    tools:context=".activities.FrameStreamActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/content_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.58" />

    <!-- Top Navigation Bar -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1a1a1a"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/top_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/btn_hide_controls"
            android:text="Active Stream Tracking"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Back"
            android:textSize="12sp"
            android:backgroundTint="#2c2c2c"
            android:textColor="#00e6ff"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_hide_controls"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_toStartOf="@id/btn_back"
            android:layout_marginEnd="8dp"
            android:layout_centerVertical="true"
            android:text="Hide UI"
            android:textSize="12sp"
            android:backgroundTint="#2c2c2c"
            android:textColor="#00e6ff"
            android:paddingHorizontal="10dp"
            android:paddingVertical="0dp" />
    </RelativeLayout>

    <!-- Interactive Workspace (Camera Finder & Overlay) -->
    <FrameLayout
        android:id="@+id/workspace_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/content_guideline">

        <!-- 1. Live Camera Preview -->
        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fitCenter" />

        <!-- 2. Transparent Image View for Drawing Real-Time Tracking Annotation Overlay -->
        <ImageView
            android:id="@+id/capturedImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <!-- 3. Dynamic Tutorial HUD Overlay -->
        <TextView
            android:id="@+id/tutorial_hud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:background="#cc1a1a1a"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Tap screen to select target"
            android:textColor="#00e6ff"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_toggle_controls"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:backgroundTint="#cc2c2c2c"
            android:minWidth="72dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="0dp"
            android:text="Menu"
            android:textColor="#00e6ff"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="42dp"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="92dp"
            android:backgroundTint="#cc2c2c2c"
            android:minWidth="42dp"
            android:padding="0dp"
            android:text="⚙"
            android:textColor="#00e6ff"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/settings_panel"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="56dp"
            android:layout_marginEnd="12dp"
            android:background="#ee1a1a1a"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracker Settings"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_experimental_prev_reference"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Experimental Prev-Frame Reference"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:checked="false"
                app:thumbTint="#00e6ff"
                app:trackTint="#555555" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_use_quality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Use Quality for Target Lost"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:checked="true"
                app:thumbTint="#00e6ff"
                app:trackTint="#555555" />

            <TextView
                android:id="@+id/lblQualityThreshold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quality lost threshold: 0.50 (on)"
                android:textColor="#aaaaaa"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seekBarQualityThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/lblIterations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iterations: 4"
                android:textColor="#aaaaaa"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seekBarIterations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="4"
                android:progress="3" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Controls & Telemetry Dashboard -->
    <ScrollView
        android:id="@+id/bottom_dashboard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1a1a1a"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/content_guideline"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/lbl_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Wait for camera..."
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Quality no longer hides detection; it only colors the tracking indicator. -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_bypass_quality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Bypass Quality Filter (Force Display)"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:checked="false"
                android:visibility="gone"
                app:thumbTint="#00e6ff"
                app:trackTint="#555555" />

            <!-- Results Section (Heatmap & Telemetry) -->
            <LinearLayout
                android:id="@+id/results_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <!-- Heatmap Output Box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/lblHeatmapIteration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Heatmap Iter: 0"
                            android:textColor="#aaaaaa"
                            android:textSize="11sp"
                            android:layout_marginBottom="6dp" />

                        <ImageView
                            android:id="@+id/heatmapImageView"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />

                        <SeekBar
                            android:id="@+id/seekBarHeatmapIteration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="0"
                            android:progress="0"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Telemetry Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginLeft="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Real-Time Telemetry"
                            android:textColor="#aaaaaa"
                            android:textSize="11sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/txt_latency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Latency: -- ms"
                            android:textColor="#33ff33"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_predicted_coords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Target Pos: (x, y)"
                            android:textColor="#33ff33"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_buffer_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Tracking Engine: Active"
                            android:textColor="#ffcc00"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Debug Crops View Panel -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visual Debug: Multi-Channel Diagnostic Crops"
                    android:textColor="#aaaaaa"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/cropHistView"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                        <TextView
                            android:id="@+id/lblHistStack"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hist Stack (I: 0, L: 0)"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:id="@+id/lblReferenceIteration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ref Iter: 0"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                        <SeekBar
                            android:id="@+id/seekBarReferenceIteration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="3"
                            android:progress="0"
                            android:layout_marginTop="2dp" />
                        <SeekBar
                            android:id="@+id/seekBarHistLayer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="15"
                            android:progress="0"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/cropCurrView"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Curr Search"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/cropFullView"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Frame"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
