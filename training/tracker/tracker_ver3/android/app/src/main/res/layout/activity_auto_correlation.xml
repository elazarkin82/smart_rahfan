<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fitsSystemWindows="true"
    tools:context=".AutoCorrelationActivity">

    <!-- Top Navigation Bar -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1a1a1a"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Static Auto-Correlation Test"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="Back"
            android:textSize="12sp"
            android:backgroundTint="#2c2c2c"
            android:textColor="#00e6ff"
            android:padding="0dp" />
    </RelativeLayout>

    <!-- Interactive Workspace (Camera Finder or Captured Image) -->
    <FrameLayout
        android:id="@+id/workspace_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_dashboard">

        <!-- 1. Live Camera Preview -->
        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible" />

        <!-- 2. Captured Image View for selection/drawing -->
        <ImageView
            android:id="@+id/capturedImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- 3. Dynamic Tutorial HUD Overlay -->
        <TextView
            android:id="@+id/tutorial_hud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:background="#cc1a1a1a"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Tap screen to take a snapshot"
            android:textColor="#00e6ff"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Bottom Controls & Telemetry Dashboard -->
    <ScrollView
        android:id="@+id/bottom_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a1a1a"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title & Reset Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/lbl_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Point camera and snapshot"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:text="Reset/Retry"
                    android:textSize="11sp"
                    android:backgroundTint="#2c2c2c"
                    android:textColor="#ff9900"
                    android:padding="0dp"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Results Section (Heatmap & Telemetry) -->
            <LinearLayout
                android:id="@+id/results_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <!-- Heatmap Output Box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Output Heatmap (64x64)"
                            android:textColor="#aaaaaa"
                            android:textSize="11sp"
                            android:layout_marginBottom="6dp" />

                        <ImageView
                            android:id="@+id/heatmapImageView"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                    </LinearLayout>

                    <!-- Telemetry Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginLeft="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Telemetry &amp; CoM"
                            android:textColor="#aaaaaa"
                            android:textSize="11sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/txt_latency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inference Latency: -- ms"
                            android:textColor="#33ff33"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_selected_coords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Selected: (x, y)"
                            android:textColor="#ffcc00"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_predicted_coords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Predicted CoM: (x, y)"
                            android:textColor="#33ff33"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_offset_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Offset Error: -- px"
                            android:textColor="#ff3333"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Debug Crops View Panel -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visual Debug: Model Input Crops (256x256)"
                    android:textColor="#aaaaaa"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/cropHistView"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hist (Mask 128)"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/cropPrevView"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prev (Mask 50)"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/cropCurrView"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="#000000"
                            android:scaleType="fitXY" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Curr (Unmasked)"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
