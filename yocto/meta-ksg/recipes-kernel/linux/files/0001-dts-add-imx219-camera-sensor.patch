From: Antigravity <antigravity@google.com>
Date: Wed, 20 May 2026 15:00:00 +0300
Subject: [PATCH] dts: Add IMX219 camera sensor to Radxa Zero 3E

Configure the Sony IMX219 camera sensor on the i2c2 bus at address 0x10,
with a 24MHz camera-clk, reset GPIO, and necessary voltage regulators.

--- a/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3e.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3e.dts
@@ -13,5 +13,29 @@
 		ethernet0 = &gmac1;
 		mmc0 = &sdmmc0;
 	};
+
+	clk_camera: camera-clk {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <24000000>;
+	};
+};
+
+&i2c2 {
+	status = "okay";
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	imx219: sensor@10 {
+		compatible = "sony,imx219";
+		reg = <0x10>;
+		clocks = <&clk_camera>;
+		clock-names = "xclk";
+		reset-gpios = <&gpio0 RK_PD3 GPIO_ACTIVE_LOW>;
+		VANA-supply = <&vcc_3v3>;
+		VDIG-supply = <&vcc_1v8>;
+		VDDL-supply = <&vcca_1v8>;
+	};
+};
 
 &gmac1 {
